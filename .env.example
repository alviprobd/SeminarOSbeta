# Firebase Configuration
# These are usually handled by firebase-applet-config.json,
# but can be overridden if needed.
# FIREBASE_PROJECT_ID=

# Gemini API Key (Required for AI features)
GEMINI_API_KEY=

# Vercel Environment Flag
VERCEL=1

# Email Configuration (Optional - can also be configured in admin dashboard)
# GMAIL_EMAIL=
# GMAIL_APP_PASSWORD=
